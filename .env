# Public DNS name for the web UI.
INVENTORY_HOST=inventory.example.local
HTTP_PORT=80
HTTPS_PORT=443
NGINX_RELOAD_INTERVAL_SECONDS=21600

# Web login for the inventory UI. Change before production.
APP_USER=admin
APP_PASSWORD=change_this_web_password
APP_TIMEZONE=Europe/Kiev

# Optional token for POST /api/hardware/report. Leave empty if unused.
HARDWARE_REPORT_TOKEN=

# PostgreSQL is created automatically by the db container on first start.
POSTGRES_DB=inventory
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change_this_db_password

# Active Directory connection. LDAPS on 636 is recommended.
# If a password contains $, write it as $$ for Docker Compose.
AD_SERVER=ldaps://dc01.example.local:636
AD_USER=EXAMPLE\\inventory.reader
AD_PASSWORD=change_this_ad_password
AD_USE_SSL=true
AD_REQUIRE_LDAPS=true
AD_VALIDATE_CERT=false
AD_CA_CERT_FILE=/certs/ad/ad-ca.crt
AD_ALLOW_INSECURE_TLS=false

# Active Directory search bases.
AD_USER_BASE_DN=DC=example,DC=local
AD_COMPUTER_PHYSICAL_BASE_DN=OU=Workstations,DC=example,DC=local
AD_COMPUTER_VIRTUAL_BASE_DN=OU=Virtual Workstations,OU=Workstations,DC=example,DC=local
AD_PHYSICAL_SEARCH_SCOPE=LEVEL
AD_VIRTUAL_SEARCH_SCOPE=SUBTREE

# Optional AD groups for automatic access flag.
# Computers in VPN group -> access flag "Да"; computers in Firewall group -> "Нет".
CHECKPOINT_VPN_GROUP_DN=CN=VPN_Access,OU=Groups,DC=example,DC=local
CHECKPOINT_FIREWALL_GROUP_DN=CN=Firewall_Access,OU=Groups,DC=example,DC=local

# Sync/export behavior.
SYNC_INTERVAL_SECONDS=300
DELETE_MISSING_COMPUTERS=true
WRITE_EXPORT_ON_CHANGE=true
EXPORT_PATH=/exports/inventory.xlsx
DNS_RESOLVE_IP=true
DNS_QUERY_TIMEOUT_SECONDS=1.5
DNS_RESOLVE_WORKERS=24
WIFI_NETWORKS=192.0.2.0/28

# Printer discovery. Use only networks that you are allowed to scan.
PRINTERS_FILE=/printers/printers.csv
PRINTER_CLEAR_BEFORE_SYNC=true
PRINTERS_DELETE_MISSING=true
PRINTER_SNMP_DISCOVERY_ENABLED=true
PRINTER_SNMP_SUBNETS=192.0.2.0/28
PRINTER_SNMP_COMMUNITY=public
PRINTER_SNMP_PORT=161
PRINTER_SNMP_TIMEOUT_SECONDS=1.0
PRINTER_SNMP_WORKERS=64
PRINTER_SNMP_MAX_HOSTS=4096
PRINTER_SNMP_REQUIRE_KEYWORDS=false
PRINTER_HTTP_DISCOVERY_ENABLED=true
PRINTER_HTTP_REQUIRE_KEYWORDS=true
PRINTER_HTTP_NAME_ENABLED=true
PRINTER_HTTP_NAME_PORTS=80,443,8080,8000,8443,631
PRINTER_HTTP_NAME_PATHS=/,/index.html,/index.htm,/home.html,/status.html,/start.htm,/main.html,/device_status.html,/general/status.html,/web/guest/en/websys/webArch/mainFrame.cgi
PRINTER_HTTP_NAME_TIMEOUT_SECONDS=1.5
PRINTER_TCP_DISCOVERY_ENABLED=true
PRINTER_TCP_PORTS=9100,515,631
PRINTER_TCP_TIMEOUT_SECONDS=0.7
PRINTER_REVERSE_DNS_ENABLED=true
PRINTER_SNMP_INCLUDE_KEYWORDS=printer,mfp,mfu,canon,hp,hewlett,packard,kyocera,xerox,epson,brother,ricoh,sharp,lexmark,konica,minolta,samsung,laserjet,officejet,deskjet,imageclass,workcentre,versalink,phaser,docucentre
PRINTER_SNMP_EXCLUDE_KEYWORDS=switch,router,firewall,vmware,esxi,linux,windows,ups,nas

# Network devices: switches, access points, routers, storage, servers.
NETWORK_DEVICE_DISCOVERY_ENABLED=false
NETWORK_DEVICE_SUBNETS=198.51.100.0/28,203.0.113.10-20
NETWORK_DEVICE_CLEAR_BEFORE_SYNC=false
NETWORK_DEVICE_DELETE_MISSING=true
NETWORK_DEVICE_SNMP_COMMUNITY=public
NETWORK_DEVICE_SNMP_PORT=161
NETWORK_DEVICE_SNMP_TIMEOUT_SECONDS=1.0
NETWORK_DEVICE_WORKERS=64
NETWORK_DEVICE_MAX_HOSTS=4096
NETWORK_DEVICE_HTTP_ENABLED=true
NETWORK_DEVICE_HTTP_PORTS=80,443,8080,8000,8443
NETWORK_DEVICE_HTTP_TIMEOUT_SECONDS=1.5
NETWORK_DEVICE_TLS_NAME_ENABLED=true
NETWORK_DEVICE_TLS_PORTS=443,8443
NETWORK_DEVICE_TLS_TIMEOUT_SECONDS=1.5
NETWORK_DEVICE_TCP_DISCOVERY_ENABLED=true
NETWORK_DEVICE_TCP_PORTS=22,23,80,443,445,3389,5985,5986,8080,8443
NETWORK_DEVICE_TCP_TIMEOUT_SECONDS=0.7
NETWORK_DEVICE_REVERSE_DNS_ENABLED=true
NETWORK_DEVICE_INCLUDE_UNNAMED=false
NETWORK_DEVICE_EXCLUDE_KEYWORDS=printer,mfp,mfu,canon,laserjet,officejet,deskjet,workcentre,phaser,pixma,imageclass

# Hardware inventory without GPO/DC scripts.
# The Docker hardware service reads computers from AD and queries each machine by WinRM/CIM.
HARDWARE_COLLECTOR_ENABLED=false
HARDWARE_COLLECT_NETWORK_SERVERS=true
HARDWARE_COLLECT_MEMORY_DETAILS=true
HARDWARE_COLLECT_MONITORS=true
HARDWARE_COLLECT_NETWORK_ADAPTERS=true
HARDWARE_MAX_MONITORS=2
HARDWARE_CLEAR_BEFORE_COLLECTION=false
HARDWARE_COLLECTION_INTERVAL_SECONDS=21600
HARDWARE_COLLECT_WORKERS=8
HARDWARE_COLLECTION_MODE=wmic
HARDWARE_WINRM_USER=EXAMPLE\\inventory.hardware
HARDWARE_WINRM_PASSWORD=change_this_winrm_password
HARDWARE_WINRM_SCHEME=http
HARDWARE_WINRM_PORT=5985
HARDWARE_WINRM_TRANSPORT=ntlm
HARDWARE_WINRM_SERVER_CERT_VALIDATION=ignore
HARDWARE_WINRM_PRECHECK_ENABLED=true
HARDWARE_WINRM_PRECHECK_TIMEOUT_SECONDS=3.0
HARDWARE_WINRM_OPERATION_TIMEOUT_SECONDS=20
HARDWARE_WINRM_READ_TIMEOUT_SECONDS=30
